            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has product id', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.data.id).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Baby Shampoo\",\n  \"slug\": \"baby-shampoo\",\n  \"description\": \"Gentle baby shampoo for sensitive skin\",\n  \"basePrice\": 50000,\n  \"weight\": 200,\n  \"sku\": \"SKU-SHAMPOO-001\",\n  \"stock\": 100,\n  \"categoryId\": \"category-id-here\"\n}"
            }
          },
          "event": [
